{
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/htmlcov/**": true,
    "**/.git/**": true,
    "**/.pytest_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/*.egg-info/**": true,
    "**/test_reports/**": true,
    "**/packaging/**": true
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/htmlcov": true,
    "**/*.pyc": true,
    "**/*.pyo": true
  },
  "search.exclude": {
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/htmlcov/**": true,
    "**/.git/**": true,
    "**/.pytest_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },
  "python.analysis.exclude": [
    ".venv/**",
    "**/__pycache__/**",
    "htmlcov/**",
    "Platforms/Python/time_warp/ui/**",
    "Platforms/Python/time_warp/hardware/**",
    "Platforms/Python/time_warp/tests/**",
    "Platforms/Python/time_warp/benchmarks/**",
    "Platforms/Python/time_warp/analytics/**",
    "Platforms/Python/time_warp/ai/**",
    "packaging/**",
    "tools/**",
    "docs/**"
  ],
  "python.analysis.indexing": true,
  "python.analysis.packageIndexDepths": [
    {
      "name": "PySide6",
      "depth": 1
    }
  ],
  "python.analysis.memory.keepLibraryLocalVariables": false,
  "pylint.args": [
    "--ignore=.venv,htmlcov,__pycache__,test_reports"
  ],
  "editor.formatOnSave": false,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
}
