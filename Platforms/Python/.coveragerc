[run]
source = time_warp
omit =
    time_warp/ui/*
    time_warp/tests/*
    time_warp/features/gamepad.py
    time_warp/features/music.py
    time_warp/features/shapes.py
    time_warp/features/particles.py
    time_warp/core/_sandbox_worker.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if TYPE_CHECKING:
    raise NotImplementedError
    @abstractmethod
    \.\.\.
    pass
