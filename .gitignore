# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
.env/

# Mypy, Pyright, Ruff caches
.mypy_cache/
.pytype/
.ruff_cache/

# VS Code (keep settings.json for workspace config, exclude user-specific files)
.vscode/*
!.vscode/settings.json

# macOS
.DS_Store

# Pytest cache
.pytest_cache/

# Archives
*.tar.gz
*.zip

# Development tools and binaries
tools/swiftly

# Visual Studio
.vs/
*.user

# Build outputs
dist/
build/
*.egg-info/

# Build artifacts
*.so
*.dylib
*.dll
*.exe
*.pdb

# Test / coverage artifacts
.coverage
coverage.xml
htmlcov/
test-results*.xml
test_report.html
test_reports/
test_output*.txt
test_graphics_failures.txt

# Debug scripts (temporary)
debug_*.py

# Generated files
DIRECTORY_TREE.txt
*.pdf

# IDE / editor swap files
*.swp
*.swo
*~

# Broken pip artifacts (files named like version specifiers)
=*
*.log
